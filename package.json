{
    "name": "runeasy-monorepo",
    "version": "1.0.0",
    "description": "RunEasy - AI-powered running training assistant",
    "private": true,
    "scripts": {
        "install:backend": "cd backend && npm install",
        "install:mobile": "cd mobile && npm install",
        "install:all": "npm run install:backend && npm run install:mobile",
        "build:backend": "cd backend && npm run build",
        "start:backend": "cd backend && npm run start:prod",
        "dev:backend": "cd backend && npm run start:dev",
        "dev:mobile": "cd mobile && npx expo start",
        "railway:build": "cd backend && npm install && npm run build",
        "railway:start": "cd backend && npm run start:prod"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/your-username/runeasy"
    },
    "keywords": [
        "running",
        "training",
        "ai",
        "strava",
        "fitness"
    ],
    "author": "RunEasy Team",
    "license": "MIT"
}